# Cloudflare Pages-style response headers. A Content-Security-Policy is deliberately
# omitted until the inline application, Google Analytics, and AdSense sources can be
# tested under Report-Only without breaking publication or advertising.
/*
  Strict-Transport-Security: max-age=31536000
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  X-XSS-Protection: 0
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), geolocation=(), microphone=(), payment=(), usb=()
  Cache-Control: public, max-age=0, must-revalidate, s-maxage=300, stale-while-revalidate=60

/feed*.xml
  ! Cache-Control
  Cache-Control: public, max-age=300, s-maxage=600, stale-while-revalidate=60

/sitemap.xml
  ! Cache-Control
  Cache-Control: public, max-age=300, s-maxage=600, stale-while-revalidate=60

/feeds.opml
  ! Cache-Control
  Cache-Control: public, max-age=300, s-maxage=600, stale-while-revalidate=60

/robots.txt
  ! Cache-Control
  Cache-Control: public, max-age=3600, s-maxage=3600, must-revalidate

/llms.txt
  ! Cache-Control
  Cache-Control: public, max-age=3600, s-maxage=3600, must-revalidate

/manifest.webmanifest
  ! Cache-Control
  Cache-Control: public, max-age=3600, must-revalidate

/service-worker.js
  ! Cache-Control
  Cache-Control: no-cache
  Service-Worker-Allowed: /

/assets/*
  ! Cache-Control
  Cache-Control: public, max-age=86400, must-revalidate

/assets/avatars/*
  ! Cache-Control
  Cache-Control: public, max-age=31536000, immutable

/assets/briefs/*
  ! Cache-Control
  Cache-Control: public, max-age=31536000, immutable
